{
    "name": "@dpuse/dpuse-development",
    "version": "0.3.673",
    "private": false,
    "description": "Actions for managing DPUse projects.",
    "license": "MIT",
    "author": "Jonathan Terrell <terrell.jm@gmail.com>",
    "type": "module",
    "sideEffects": false,
    "homepage": "https://www.dpuse.app",
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-development/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dpuse/dpuse-development.git"
    },
    "module": "./dist/dpuse-development.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-development.es.js",
            "types": "./dist/types/src/index.d.ts"
        },
        "./prettierrc": "./.prettierrc.json",
        "./license-report-config": "./licenses/license-report-config.json"
    },
    "files": [
        ".editorconfig",
        ".gitattributes",
        ".gitattributes_default",
        ".gitignore_default",
        ".gitignore_npm_published",
        ".markdownlint.json",
        ".ncurc.json",
        ".prettierrc.json",
        "dist",
        "eslint.config.default.js",
        "LICENSE",
        "tsconfig.json",
        "tsconfig.default.json",
        "tsconfig.scripts.json",
        "vite.config.default.ts",
        "vite.config.tool.ts",
        "vite.config.wasm.ts",
        "vitest.config.ts"
    ],
    "engines": {
        "node": ">=22",
        "npm": ">=11"
    },
    "allowScripts": {
        "fsevents@2.3.3": true,
        "unrs-resolver@1.11.1": true
    },
    "scripts": {
        "audit": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.auditDependencies())\"",
        "build": "vite build && node -e \"import('./dist/dpuse-development.es.js').then(m => m.documentBundleSizes())\"",
        "check": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.checkConfigFiles())\" && node -e \"import('./dist/dpuse-development.es.js').then(m => m.checkDependencies())\"",
        "document": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.documentDependencies(''))\"",
        "format": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.formatCode())\"",
        "lint": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.lintCode())\"",
        "release": "npm run sync && gh release create \"v$(npm pkg get version | tr -d '\"')\" --target \"$(git rev-parse HEAD)\" --generate-notes --latest",
        "sync": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.testProject())\"",
        "update": "node -e \"import('./dist/dpuse-development.es.js').then(m => m.updateDPUseDependencies(['eslint', 'shared']))\""
    },
    "dependencies": {
        "@dpuse/dpuse-shared": "^0.3.735",
        "acorn": "^8.17.0",
        "acorn-typescript": "^1.4.13",
        "license-checker-rseidelsohn": "^5.0.1",
        "npm-check-updates": "^22.2.9",
        "valibot": "^1.4.2"
    },
    "devDependencies": {
        "@dpuse/eslint-config-dpuse": "^1.0.105",
        "@types/node": "^26.1.0",
        "eslint": "^10.6.0",
        "prettier": "^3.9.4",
        "sonda": "^0.14.0",
        "type-fest": "^5.8.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vite-plugin-dts": "^5.0.3",
        "vite-plugin-wasm": "^3.6.0",
        "vitest": "^4.1.10"
    }
}